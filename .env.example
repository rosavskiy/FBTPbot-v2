# Active LLM provider
LLM_PROVIDER=yandex
SHOW_LLM_IN_CHAT=false

# YandexGPT
YANDEX_API_KEY=
YANDEX_FOLDER_ID=
YANDEX_GPT_MODEL=yandexgpt
YANDEX_EMBEDDING_MODEL=text-search-query

# DeepSeek
DEEPSEEK_API_KEY=
DEEPSEEK_MODEL=deepseek-chat

# ChromaDB
CHROMA_PERSIST_DIR=./data/chroma_db

# Database
DATABASE_URL=sqlite+aiosqlite:///./data/support.db

# Telegram
TELEGRAM_BOT_TOKEN=
TELEGRAM_SUPPORT_CHAT_ID=

# Application
APP_HOST=0.0.0.0
APP_PORT=8000
APP_DEBUG=false

# RAG
RAG_CHUNK_SIZE=800
RAG_CHUNK_OVERLAP=200
RAG_TOP_K=5
RAG_CONFIDENCE_THRESHOLD=0.3

# Contact Reasons
CONTACT_REASONS_PATH=./data/contact_reasons.json

# Google Sheets логирование
GOOGLE_SHEETS_CREDENTIALS_FILE=./data/google_credentials.json
GOOGLE_SHEETS_SPREADSHEET_ID=
GOOGLE_SHEETS_WORKSHEET=QnA

# CORS (JSON array)
CORS_ORIGINS=["https://yourdomain.com"]
